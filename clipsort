#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="clipsort"

# Check that the Docker image exists
if ! docker image inspect "${IMAGE_NAME}" >/dev/null 2>&1; then
    echo "Error: Docker image '${IMAGE_NAME}' not found." >&2
    echo "Build it first by running: ./build" >&2
    exit 1
fi

# Find the subcommand (first non-flag argument)
subcommand=""
for arg in "$@"; do
    if [[ "$arg" != -* ]]; then
        subcommand="$arg"
        break
    fi
done

case "$subcommand" in
    organize|detect)
        # These commands take: SUBCOMMAND [OPTIONS] INPUT_DIR OUTPUT_DIR
        # Parse to find the two positional directory args and mount them.
        passthrough=()
        input_dir=""
        output_dir=""
        positional_count=0
        skip_next=false
        found_sub=false

        for arg in "$@"; do
            if $skip_next; then
                skip_next=false
                passthrough+=("$arg")
                continue
            fi

            if ! $found_sub; then
                # Haven't seen the subcommand yet
                passthrough+=("$arg")
                if [[ "$arg" == "$subcommand" ]]; then
                    found_sub=true
                fi
                continue
            fi

            # After the subcommand: distinguish flags from positionals
            if [[ "$arg" == -* ]]; then
                passthrough+=("$arg")
                # Flags that consume the next argument as a value
                case "$arg" in
                    --report-file|--scan-seconds|--sample-rate) skip_next=true ;;
                esac
            else
                positional_count=$((positional_count + 1))
                if [[ $positional_count -eq 1 ]]; then
                    input_dir="$arg"
                elif [[ $positional_count -eq 2 ]]; then
                    output_dir="$arg"
                else
                    passthrough+=("$arg")
                fi
            fi
        done

        if [[ -z "$input_dir" || -z "$output_dir" ]]; then
            # Let Click handle the missing-argument error
            exec docker run --rm "${IMAGE_NAME}" "$@"
        fi

        abs_input="$(cd "$input_dir" 2>/dev/null && pwd)" || {
            echo "Error: Input directory '${input_dir}' does not exist." >&2
            exit 1
        }
        abs_output="$(mkdir -p "$output_dir" && cd "$output_dir" && pwd)"

        exec docker run --rm \
            -v "${abs_input}:/input:ro" \
            -v "${abs_output}:/output" \
            "${IMAGE_NAME}" "${passthrough[@]}" /input /output
        ;;

    qr-generate)
        # No positional dir args — mount pwd as /work so output files land on host
        exec docker run --rm \
            -v "$(pwd):/work" \
            -w /work \
            "${IMAGE_NAME}" "$@"
        ;;

    *)
        # --help, --version, unknown commands — passthrough
        exec docker run --rm "${IMAGE_NAME}" "$@"
        ;;
esac
